# Copy this value into Netlify site settings, not into js/config.js.
GEMINI_API_KEY=replace-with-your-gemini-api-key

# Optional. The app defaults to gemini-2.5-flash.
GEMINI_MODEL=gemini-2.5-flash

# Optional. Comma-separated server-side fallback models. Only the first distinct fallback is used.
GEMINI_FALLBACK_MODELS=gemini-3.5-flash

# Kakao Login (server-side Netlify environment variables)
KAKAO_REST_API_KEY=replace-with-your-kakao-rest-api-key
KAKAO_CLIENT_SECRET=replace-with-your-kakao-client-secret
KAKAO_REDIRECT_URI=http://localhost:8888/api/auth/kakao/callback
SESSION_SECRET=replace-with-a-random-secret-at-least-32-characters
